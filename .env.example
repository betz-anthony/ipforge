DB_PASSWORD=ipam

# Auth — JWT signing key. If left empty, a strong key is generated and
# persisted automatically on first start. Set it explicitly when running
# multiple API instances so they share one signing key.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=

# Credential encryption — encrypts provider/LDAP passwords at rest. If empty,
# those secrets are stored as plaintext in the database. Strongly recommended.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=

MS_WINRM_HOST=your-dc.domain.local
MS_WINRM_USER=DOMAIN\svcaccount
MS_WINRM_PASSWORD=yourpassword
MS_WINRM_TRANSPORT=ntlm

MS_DNS_SERVER=your-dns-server.domain.local
MS_DHCP_SERVER=your-dhcp-server.domain.local
