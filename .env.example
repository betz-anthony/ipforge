DB_PASSWORD=ipam

# Auth — JWT signing key. If left empty, a strong key is generated and
# persisted automatically on first start. Set it explicitly when running
# multiple API instances so they share one signing key.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=

# Credential encryption — encrypts provider/LDAP passwords at rest. If empty,
# those secrets are stored as plaintext in the database. Strongly recommended.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=

# DNS/DHCP providers are NOT configured here. Add them at runtime in the UI
# under Settings → Providers (WinRM host, Pi-hole URL, BIND TSIG key, Kea
# Control Agent URL, cloud API tokens, …); credentials are encrypted at rest
# with SECRET_KEY.

# ── Optional server tuning (defaults shown; uncomment to override) ──────────
# DATABASE_URL=postgresql://ipam:ipam@db:5432/ipam
# DEFAULT_ADMIN_PASSWORD=admin
# SYNC_MODE=background
# SCAN_INTERVAL_MINUTES=30
# UTIL_WARN_THRESHOLD=80
# UTIL_CRITICAL_THRESHOLD=95
# STALE_RECLAIM_DAYS=30

# ── Optional LDAP / AD (disabled by default) ────────────────────────────────
# LDAP_ENABLED=true
# LDAP_HOST=dc.domain.local
# LDAP_PORT=389
# LDAP_BIND_DN=CN=svc,OU=Service,DC=domain,DC=local
# LDAP_BIND_PASSWORD=
# LDAP_BASE_DN=DC=domain,DC=local
# LDAP_GROUP_ADMIN=
# LDAP_GROUP_OPERATOR=
# LDAP_GROUP_READONLY=
